# Discord bot token (https://discord.com/developers/applications)
DISCORD_TOKEN=

# Google Generative AI key (https://ai.google.dev/)
GOOGLE_API_KEY=

# Model + behavior knobs
GEMINI_MODEL=gemini-2.5-flash
LOG_LEVEL=info

# Optional scoping (comma-separated IDs). Leave blank to listen everywhere.
ALLOWED_GUILD_IDS=
ALLOWED_CHANNEL_IDS=

# Per-user-per-thread cooldown (seconds). 0 disables.
COOLDOWN_SECONDS=30

# How many previous messages to pull as context for the agent. Max 50.
# 0 = only consider the message that mentions the bot, no prior history.
CONTEXT_LIMIT=0
