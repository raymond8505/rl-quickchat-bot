{
  "name": "rl-discord-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Discord bot that replies to thread messages with the most relevant Rocket League quickchat.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite-node --watch src/index.ts",
    "build": "vite build",
    "start": "node dist/index.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@langchain/core": "^0.3.0",
    "@langchain/google-genai": "^0.2.0",
    "@langchain/langgraph": "^0.2.0",
    "discord.js": "^14.16.0",
    "dotenv": "^16.4.5",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "pino-pretty": "^11.2.2",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vite-node": "^2.1.0",
    "vitest": "^2.1.0"
  }
}
